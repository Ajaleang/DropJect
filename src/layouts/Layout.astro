---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO, { type SEOProps } from '../components/SEO.astro';

export interface LayoutProps {
	seo?: SEOProps;
}

const { seo } = Astro.props;
---
<!doctype html>
<html lang="es" class="scroll-smooth bg-brand-black text-white">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Default SEO (can be overridden by page-specific SEO) -->
		<SEO 
			title={seo?.title || 'DropJect | Sublimación Industrial y Dotaciones Corporativas'}
			description={seo?.description || 'Especialistas en sublimación de alta calidad en Bogotá. Dotaciones corporativas, uniformes, material POP y producción textil con colores vibrantes y durabilidad garantizada.'}
			keywords={seo?.keywords}
			canonicalURL={seo?.canonicalURL}
			ogImage={seo?.ogImage}
			type={seo?.type}
		/>
	</head>
	<body class="flex flex-col min-h-screen font-sans">
		<Header />
		<main class="flex-grow pt-20">
			<slot />
		</main>
		<Footer />

		<!-- Floating WhatsApp Button -->
		<div class="fixed bottom-6 right-6 z-40 flex flex-col items-end gap-4 pointer-events-none">
			<!-- Popup Message -->
			<div id="wa-popup" class="bg-white text-brand-black p-4 rounded-xl shadow-2xl relative w-64 opacity-0 translate-y-4 transition-all duration-500 ease-out origin-bottom-right border border-gray-100/50 pointer-events-auto">
				<button id="wa-popup-close" class="absolute top-2 right-2 text-gray-400 hover:text-gray-600 transition-colors focus:outline-none" aria-label="Cerrar">
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
				</button>
				<p class="text-sm font-semibold mb-1 pr-4">¡Hola! 👋</p>
				<p class="text-xs text-gray-600 leading-relaxed">¿Necesitas ayuda con tu proyecto? Escríbenos y te asesoramos.</p>
				<!-- Triangle pointer -->
				<div class="absolute -bottom-2 right-6 w-4 h-4 bg-white rotate-45 border-b border-r border-gray-100/50 z-[-1]"></div>
			</div>

			<a 
				href="https://wa.me/573117694342" 
				target="_blank" 
				rel="noopener noreferrer"
				class="bg-[#25D366] text-white p-4 rounded-full shadow-2xl hover:bg-[#20BE5C] hover:scale-110 transition-transform duration-300 group flex items-center justify-center animate-bounce-slow pointer-events-auto"
				aria-label="Contactar por WhatsApp"
			>
				<svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.88-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
				<!-- Tooltip hover -->
				<span class="absolute right-full mr-4 bg-white text-brand-black px-3 py-1 rounded-md text-sm font-semibold opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap shadow-lg pointer-events-none">
					¿Necesitas ayuda?
				</span>
			</a>
		</div>

		<script>
			document.addEventListener('DOMContentLoaded', () => {
				const popup = document.getElementById('wa-popup');
				const closeBtn = document.getElementById('wa-popup-close');
				
				if (popup && closeBtn) {
					// Mostrar después de 3 segundos
					setTimeout(() => {
						popup.classList.remove('opacity-0', 'translate-y-4');
						popup.classList.add('opacity-100', 'translate-y-0');
					}, 3000);

					// Ocultar al cerrar
					closeBtn.addEventListener('click', (e) => {
						e.preventDefault();
						e.stopPropagation();
						popup.classList.add('opacity-0', 'translate-y-4');
						popup.classList.remove('opacity-100', 'translate-y-0');
					});

					// Ocultar automáticamente después de 15 segundos
					setTimeout(() => {
						popup.classList.add('opacity-0', 'translate-y-4');
						popup.classList.remove('opacity-100', 'translate-y-0');
					}, 15000);
				}
			});
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
