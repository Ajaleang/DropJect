---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Hero Section -->
  <section class="relative bg-brand-black w-full min-h-[80vh] flex items-center justify-center overflow-hidden">
    <!-- Abstract gradient background representing sublimation heat / color -->
    <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_center,_var(--color-brand-gray)_0%,_transparent_70%)]"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center z-10 flex flex-col items-center">
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 tracking-tight leading-tight">
        Exprime el Color.<br />
        <span class="text-brand-light">Plasma tus Ideas.</span>
      </h1>
      <p class="mt-4 text-xl text-brand-gray max-w-2xl mx-auto mb-10">
        Especialistas en sublimación de alta resolución. Calidad superior, colores vibrantes y durabilidad garantizada en cada producto.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contacto" class="px-8 py-3 bg-white text-brand-black rounded-md font-semibold text-lg hover:bg-brand-beige transition-all shadow-[0_0_20px_rgba(255,255,255,0.2)]">
          Cotizar Ahora
        </a>
        <a href="#servicios" class="px-8 py-3 bg-brand-dark/50 text-white border border-brand-gray rounded-md font-semibold text-lg hover:bg-brand-dark transition-all">
          Ver Servicios
        </a>
      </div>
    </div>
  </section>

  <!-- Servicios Section -->
  <section id="servicios" class="py-24 bg-brand-beige text-brand-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">Nuestros Servicios</h2>
        <p class="text-brand-dark max-w-2xl mx-auto">Soluciones integrales de sublimación para tu empresa, evento o marca personal.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Servicio 1 -->
        <div class="bg-white rounded-xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 border border-brand-light/50 group">
          <div class="w-14 h-14 bg-brand-black rounded-lg mb-6 flex items-center justify-center text-white group-hover:bg-brand-gray transition-colors">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4m18-6V5a2 2 0 00-2-2H5a2 2 0 00-2 2v4M4 9h16M4 15h16" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Tazas y Cerámica</h3>
          <p class="text-brand-dark text-sm leading-relaxed mb-6">Sublimación en tazas de diferentes tamaños, termos, y cerámica. Perfectos para regalos corporativos o souvenirs.</p>
        </div>

        <!-- Servicio 2 -->
        <div class="bg-white rounded-xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 border border-brand-light/50 group">
          <div class="w-14 h-14 bg-brand-black rounded-lg mb-6 flex items-center justify-center text-white group-hover:bg-brand-gray transition-colors">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Textil y Publicidad</h3>
          <p class="text-brand-dark text-sm leading-relaxed mb-6">Impresión en camisetas, gorras, bolsas ecológicas de poliéster. Colores penetrantes que no se destiñen con el lavado.</p>
        </div>

        <!-- Servicio 3 -->
        <div class="bg-white rounded-xl p-8 shadow-sm hover:shadow-xl transition-shadow duration-300 border border-brand-light/50 group">
          <div class="w-14 h-14 bg-brand-black rounded-lg mb-6 flex items-center justify-center text-white group-hover:bg-brand-gray transition-colors">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Gran Formato y POP</h3>
          <p class="text-brand-dark text-sm leading-relaxed mb-6">Material publicitario (POP), pendones de tela, banderas y exhibidores. Máximo impacto visual para tu negocio.</p>
        </div>
      </div>
    </div>
  </section>
  <!-- Portafolio Section -->
  <section id="portafolio" class="py-24 bg-brand-black text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold mb-4 tracking-tight">Nuestro Trabajo</h2>
        <p class="text-brand-gray max-w-2xl mx-auto">Explora algunos de nuestros proyectos recientes. Calidad que se ve y se siente.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Item 1 -->
        <div class="group relative aspect-square overflow-hidden rounded-xl bg-brand-dark cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-t from-brand-black/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10 flex flex-col justify-end p-6">
            <h3 class="text-xl font-bold text-white">Tazas Corporativas</h3>
            <p class="text-brand-light text-sm">Empresa XYZ</p>
          </div>
          <!-- Placeholder (Simulando imagen real) -->
          <div class="w-full h-full flex items-center justify-center text-brand-gray group-hover:scale-110 transition-transform duration-500">Img 1</div>
        </div>

        <!-- Item 2 -->
        <div class="group relative aspect-square overflow-hidden rounded-xl bg-brand-dark cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-t from-brand-black/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10 flex flex-col justify-end p-6">
            <h3 class="text-xl font-bold text-white">Uniformes Deportivos</h3>
            <p class="text-brand-light text-sm">Equipo Local</p>
          </div>
          <div class="w-full h-full flex items-center justify-center text-brand-gray group-hover:scale-110 transition-transform duration-500">Img 2</div>
        </div>

        <!-- Item 3 -->
        <div class="group relative aspect-square overflow-hidden rounded-xl bg-brand-dark cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-t from-brand-black/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10 flex flex-col justify-end p-6">
            <h3 class="text-xl font-bold text-white">Material POP</h3>
            <p class="text-brand-light text-sm">Campaña Verano</p>
          </div>
          <div class="w-full h-full flex items-center justify-center text-brand-gray group-hover:scale-110 transition-transform duration-500">Img 3</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Nosotros / Proceso -->
  <section id="nosotros" class="py-24 bg-brand-light text-brand-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight">El Arte de<br/>Sublimar</h2>
          <p class="text-brand-dark mb-6 text-lg leading-relaxed">
            En DropJect no solo imprimimos, damos vida a tus ideas. Utilizamos tecnología de punta y tintas de la más alta calidad para asegurar que cada color sea vibrante y resistente al paso del tiempo.
          </p>
          <ul class="space-y-4">
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-black text-white flex items-center justify-center text-xs">1</span>
              <span class="font-medium">Envíanos tu diseño o idea.</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-black text-white flex items-center justify-center text-xs">2</span>
              <span class="font-medium">Ajustamos la planimetría y colores.</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-black text-white flex items-center justify-center text-xs">3</span>
              <span class="font-medium">Sublimamos con precisión térmica.</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-black text-white flex items-center justify-center text-xs">4</span>
              <span class="font-medium">Entrega de producto finalizado.</span>
            </li>
          </ul>
        </div>
        <div class="aspect-[4/3] bg-brand-beige rounded-2xl flex items-center justify-center shadow-lg">
          <span class="text-brand-gray/50 font-medium">Foto del Taller / Equipo</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Contacto -->
  <section id="contacto" class="py-24 bg-brand-black text-white border-t border-brand-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight">¿Listo para empezar?</h2>
      <p class="text-brand-gray mb-10 text-lg">
        Cotiza tu proyecto hoy mismo. Te responderemos en tiempo récord con la mejor propuesta.
      </p>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-12 text-left">
        <!-- Info y Botones Directos -->
        <div class="flex flex-col justify-center">
          <h3 class="text-2xl font-bold mb-6 text-white">Hablemos sobre tu idea</h3>
          <p class="text-brand-gray mb-8">
            Ya sea un pedido por volumen corporativo o un proyecto personalizado, nuestro equipo está listo para asesorarte con los mejores materiales de sublimación.
          </p>
          
          <div class="space-y-4">
            <a href="https://wa.me/1234567890" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 bg-brand-dark rounded-lg hover:bg-brand-gray/20 transition-colors border border-brand-gray/20">
              <div class="w-12 h-12 bg-[#25D366]/10 rounded-full flex items-center justify-center text-[#25D366]">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.88-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
              </div>
              <div>
                <p class="font-bold text-white">Atención Rápida por WhatsApp</p>
                <p class="text-sm text-brand-gray">+123 456 7890</p>
              </div>
            </a>
            
            <a href="mailto:contacto@dropject.com" class="flex items-center gap-3 p-4 bg-brand-dark rounded-lg hover:bg-brand-gray/20 transition-colors border border-brand-gray/20">
              <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center text-white">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="font-bold text-white">Envíanos un Correo</p>
                <p class="text-sm text-brand-gray">contacto@dropject.com</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Formulario Web3Forms -->
        <div class="bg-brand-dark p-8 rounded-2xl border border-brand-gray/20 shadow-2xl relative">
          <!-- TODO: Add Web3Forms Action Here -->
          <form action="#" method="POST" class="space-y-6" id="contactForm">
            <!-- Access Key oculta de Web3Forms irá aquí -->
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-brand-light mb-2">Nombre *</label>
                <input type="text" id="name" name="name" required class="w-full bg-brand-black border border-brand-gray/30 rounded-md px-4 py-3 text-white focus:outline-none focus:border-brand-light focus:ring-1 focus:ring-brand-light transition-colors" placeholder="Tu nombre o empresa">
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-brand-light mb-2">Correo Electrónico *</label>
                <input type="email" id="email" name="email" required class="w-full bg-brand-black border border-brand-gray/30 rounded-md px-4 py-3 text-white focus:outline-none focus:border-brand-light focus:ring-1 focus:ring-brand-light transition-colors" placeholder="correo@ejemplo.com">
              </div>
            </div>
            
            <div>
              <label for="phone" class="block text-sm font-medium text-brand-light mb-2">Teléfono (Opcional)</label>
              <input type="tel" id="phone" name="phone" class="w-full bg-brand-black border border-brand-gray/30 rounded-md px-4 py-3 text-white focus:outline-none focus:border-brand-light focus:ring-1 focus:ring-brand-light transition-colors" placeholder="+123 456 7890">
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-brand-light mb-2">Mensaje / Proyecto *</label>
              <textarea id="message" name="message" rows="4" required class="w-full bg-brand-black border border-brand-gray/30 rounded-md px-4 py-3 text-white focus:outline-none focus:border-brand-light focus:ring-1 focus:ring-brand-light transition-colors resize-none" placeholder="Cuéntanos qué necesitas sublimar, cantidades estimadas, etc."></textarea>
            </div>

            <button type="submit" class="w-full bg-white text-brand-black py-4 rounded-md font-bold text-lg hover:bg-brand-beige transition-colors shadow-lg">
              Enviar Cotización
            </button>
            <p class="text-xs text-brand-gray text-center mt-4">
              Protegido contra Spam. No compartiremos tus datos.
            </p>
          </form>
        </div>
    </div>
  </section>
</Layout>
