---
import Layout from '../layouts/Layout.astro';

const seo = {
	title: 'Nosotros | DropJect - 13 Años de Experiencia en Sublimación',
	description: 'Más de 13 años de experiencia en serigrafía y sublimación en Colombia. Especialistas en técnicas premium, calidad superior y durabilidad extrema para marcas exigentes.',
	keywords: 'sobre DropJect, empresa de sublimación Bogotá, taller de serigrafía Colombia, experiencia estampado textil, historia DropJect',
	canonicalURL: '/nosotros',
	type: 'website'
};
---

<Layout seo={seo}>
  <section class="bg-brand-black pt-32 pb-16 px-4 sm:px-6 lg:px-8 text-center border-b border-brand-dark">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Sobre Nosotros</h1>
    <p class="text-brand-gray max-w-2xl mx-auto text-lg">
      Más de 13 años de experiencia en la industria textil y serigráfica en Colombia.
    </p>
  </section>

  <!-- Nosotros / Proceso -->
  <section class="py-24 bg-brand-light text-brand-black min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tight">Prendas con<br/>Personalidad</h2>
          <p class="text-brand-dark mb-6 text-lg leading-relaxed">
            En <strong>DropJect</strong> no hacemos simples uniformes, creamos prendas de vestir con actitud. Nuestro enfoque absoluto está en la <strong>calidad superior y la durabilidad extrema</strong> de los resultados.
          </p>
          <p class="text-brand-dark mb-8 text-lg leading-relaxed">
            Tras más de una década perfeccionando el arte de la serigrafía en Colombia, ofrecemos un nivel de detalle milimétrico y una biblioteca inigualable de efectos y acabados premium (relieve 3D, flock, reflectivos, puff) para elevar el diseño de las marcas más exigentes del streetwear y la música.
          </p>
          <ul class="space-y-4 mb-8">
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-black text-white flex items-center justify-center text-xs">✓</span>
              <span class="font-medium">Atención meticulosa al detalle en cada trazo.</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-black text-white flex items-center justify-center text-xs">✓</span>
              <span class="font-medium">Catálogo extenso de técnicas especiales de estampado.</span>
            </li>
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-brand-black text-white flex items-center justify-center text-xs">✓</span>
              <span class="font-medium">Solidez garantizada contra lavados intensivos.</span>
            </li>
          </ul>
          
          <a href="/tecnicas" class="px-8 py-4 bg-brand-black text-white rounded-md font-bold text-lg hover:bg-brand-dark transition-all shadow-xl inline-block mt-4">
            Explorar Nuestro Catálogo de Técnicas
          </a>
        </div>
        <div class="aspect-[4/3] bg-brand-beige rounded-2xl flex items-center justify-center shadow-lg overflow-hidden relative group">
          <div class="absolute inset-0 bg-brand-dark/20 group-hover:bg-transparent transition-colors z-10"></div>
          <span class="text-brand-gray/50 font-medium z-0">Foto del Taller Serigráfico</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
