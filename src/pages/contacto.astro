---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Contacto Section Web3Forms -->
  <section class="min-h-screen pt-32 pb-24 bg-brand-black text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 tracking-tight">¿Listo para empezar?</h1>
      <p class="text-brand-gray mb-10 text-lg">
        Cotiza tu proyecto hoy mismo. Te responderemos en tiempo récord con la mejor propuesta.
      </p>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-12 text-left">
        <!-- Info y Botones Directos -->
        <div class="flex flex-col justify-center">
          <h3 class="text-2xl font-bold mb-6 text-white">Hablemos sobre tu idea</h3>
          <p class="text-brand-gray mb-8">
            Ya sea un pedido por volumen corporativo o un proyecto personalizado, nuestro equipo está listo para asesorarte con los mejores materiales de sublimación.
          </p>
          
          <div class="space-y-4">
            <a href="https://wa.me/1234567890" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 bg-brand-dark rounded-lg hover:bg-brand-gray/20 transition-colors border border-brand-gray/20">
              <div class="w-12 h-12 bg-[#25D366]/10 rounded-full flex items-center justify-center text-[#25D366]">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.88-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
              </div>
              <div>
                <p class="font-bold text-white">Atención Rápida por WhatsApp</p>
                <p class="text-sm text-brand-gray">+123 456 7890</p>
              </div>
            </a>
            
            <a href="mailto:contacto@dropject.com" class="flex items-center gap-3 p-4 bg-brand-dark rounded-lg hover:bg-brand-gray/20 transition-colors border border-brand-gray/20">
              <div class="w-12 h-12 bg-white/10 rounded-full flex items-center justify-center text-white">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="font-bold text-white">Envíanos un Correo</p>
                <p class="text-sm text-brand-gray">contacto@dropject.com</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Formulario Web3Forms -->
        <div class="bg-brand-dark p-8 rounded-2xl border border-brand-gray/20 shadow-2xl relative">
          <!-- TODO: Add Web3Forms Action Here -->
          <form action="#" method="POST" class="space-y-6" id="contactForm">
            <!-- Access Key oculta de Web3Forms irá aquí -->
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-brand-light mb-2">Nombre *</label>
                <input type="text" id="name" name="name" required class="w-full bg-brand-black border border-brand-gray/30 rounded-md px-4 py-3 text-white focus:outline-none focus:border-brand-light focus:ring-1 focus:ring-brand-light transition-colors" placeholder="Tu nombre o empresa">
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-brand-light mb-2">Correo Electrónico *</label>
                <input type="email" id="email" name="email" required class="w-full bg-brand-black border border-brand-gray/30 rounded-md px-4 py-3 text-white focus:outline-none focus:border-brand-light focus:ring-1 focus:ring-brand-light transition-colors" placeholder="correo@ejemplo.com">
              </div>
            </div>
            
            <div>
              <label for="phone" class="block text-sm font-medium text-brand-light mb-2">Teléfono (Opcional)</label>
              <input type="tel" id="phone" name="phone" pattern="[0-9+\-\s]+" title="Solo se permiten números, espacios, y los símbolos + y -" class="w-full bg-brand-black border border-brand-gray/30 rounded-md px-4 py-3 text-white focus:outline-none focus:border-brand-light focus:ring-1 focus:ring-brand-light transition-colors" placeholder="+123 456 7890">
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-brand-light mb-2">Mensaje / Proyecto *</label>
              <textarea id="message" name="message" rows="4" required class="w-full bg-brand-black border border-brand-gray/30 rounded-md px-4 py-3 text-white focus:outline-none focus:border-brand-light focus:ring-1 focus:ring-brand-light transition-colors resize-none" placeholder="Cuéntanos qué necesitas sublimar, cantidades estimadas, etc."></textarea>
            </div>

            <button id="submitBtn" type="submit" class="w-full bg-white text-brand-black py-4 rounded-md font-bold text-lg hover:bg-brand-beige transition-colors shadow-lg flex justify-center items-center gap-2">
              <span id="submitText">Enviar Cotización</span>
              <svg id="submitSpinner" class="animate-spin h-5 w-5 text-brand-black hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
            <p class="text-xs text-brand-gray text-center mt-4">
              Protegido contra Spam (hCaptcha). No compartiremos tus datos.
            </p>
          </form>
        </div>
    </div>
  </section>

  <!-- Toast Notification (Popup) -->
  <div id="toast" class="fixed bottom-4 right-4 max-w-sm w-full bg-white rounded-lg shadow-2xl overflow-hidden transform translate-y-[150%] transition-transform duration-300 z-50 pointer-events-none">
    <div class="p-4 flex items-start gap-4">
      <div id="toastIconSuccess" class="flex-shrink-0 w-8 h-8 rounded-full bg-green-100 text-green-600 flex items-center justify-center hidden">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <div id="toastIconError" class="flex-shrink-0 w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center hidden">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </div>
      <div class="flex-1">
        <h4 id="toastTitle" class="text-brand-black font-bold mb-1">Título</h4>
        <p id="toastMessage" class="text-sm text-brand-dark">Mensaje descriptivo</p>
      </div>
      <button id="closeToastBtn" class="text-brand-gray hover:text-brand-black transition-colors pointer-events-auto">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

</Layout>

<script>
  // Lógica de validación y envío del formulario
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const submitText = document.getElementById('submitText');
    const submitSpinner = document.getElementById('submitSpinner');
    
    // Elementos del Toast
    const toast = document.getElementById('toast');
    const toastTitle = document.getElementById('toastTitle');
    const toastMessage = document.getElementById('toastMessage');
    const toastIconSuccess = document.getElementById('toastIconSuccess');
    const toastIconError = document.getElementById('toastIconError');
    const closeToastBtn = document.getElementById('closeToastBtn');
    
    let toastTimeout;

    const showToast = (type: 'success' | 'error', title: string, message: string) => {
      // Limpiar timeout previo
      if (toastTimeout) clearTimeout(toastTimeout);
      
      // Configurar contenido
      if (toastTitle) toastTitle.textContent = title;
      if (toastMessage) toastMessage.textContent = message;
      
      // Configurar iconos
      if (type === 'success') {
        toastIconSuccess?.classList.remove('hidden');
        toastIconError?.classList.add('hidden');
        if(toastTitle) toastTitle.classList.replace('text-red-600', 'text-green-600') || toastTitle.classList.add('text-green-600');
      } else {
        toastIconSuccess?.classList.add('hidden');
        toastIconError?.classList.remove('hidden');
        if(toastTitle) toastTitle.classList.replace('text-green-600', 'text-red-600') || toastTitle.classList.add('text-red-600');
      }

      // Mostrar Toast (eliminar la clase que lo esconde abajo)
      toast?.classList.remove('translate-y-[150%]');
      toast?.classList.add('pointer-events-auto');

      // Ocultar automáticamente después de 5 segundos
      toastTimeout = setTimeout(() => {
        hideToast();
      }, 5000);
    };

    const hideToast = () => {
      toast?.classList.add('translate-y-[150%]');
      toast?.classList.remove('pointer-events-auto');
    };

    closeToastBtn?.addEventListener('click', hideToast);

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault(); // Evita que la página recargue
        
        // Extraer datos
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        // Estado de "Cargando"
        submitBtn.disabled = true;
        submitText!.textContent = 'Enviando...';
        submitSpinner?.classList.remove('hidden');

        try {
          // --- AQUÍ IRÁ LA LLAMADA A LA API ---
          // Por ahora simulamos una petición de 1.5 segundos
          await new Promise(resolve => setTimeout(resolve, 1500));
          
          /* EJEMPLO DE CÓMO SERÁ LA LLAMADA REAL CUANDO TENGAMOS LA API:
          const response = await fetch('TU_URL_DE_API_AQUI', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if(!response.ok) throw new Error('Error en el servidor');
          */

          // Éxito:
          showToast('success', '¡Mensaje Enviado!', 'Hemos recibido tu solicitud. Te contactaremos muy pronto.');
          form.reset(); // Limpiar el formulario
          
        } catch (error) {
          // Error:
          console.error(error);
          showToast('error', 'Error al enviar', 'Ocurrió un problema de conexión. Por favor intenta de nuevo.');
        } finally {
          // Restaurar estado del botón
          submitBtn.disabled = false;
          submitText!.textContent = 'Enviar Cotización';
          submitSpinner?.classList.add('hidden');
        }
      });
    }
  });
</script>
