---

<Layout seo={seo}>
  <!-- Hero Section Tecnicas -->
  <section class="bg-brand-black pt-32 pb-16 px-4 sm:px-6 lg:px-8 text-center border-b border-brand-dark">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Biblioteca de Técnicas</h1>
    <p class="text-brand-gray max-w-2xl mx-auto text-lg">
      Más de 15 acabados premium en serigrafía para separar tu marca del resto.
    </p>
  </section>

  <!-- Filtro o Contexto Visual -->
  <section class="py-12 bg-brand-light text-brand-black border-b border-brand-gray/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
       <p class="text-xl font-medium text-brand-dark max-w-3xl mx-auto leading-relaxed">
         Un diseño promedio se convierte en una <strong>pieza de colección</strong> cuando usamos la técnica correcta. Explora nuestro catálogo de efectos especiales; desde el tacto nulo del despigmentado hasta el volumen extremo del Puff y 3D.
       </p>
    </div>
  </section>

  <!-- Catálogo Grid -->
  <section class="py-24 bg-brand-light text-brand-black min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        {tecnicas.map((tecnica) => (
          <div class="bg-white rounded-xl p-8 shadow-sm hover:shadow-2xl transition-all duration-300 border border-brand-light/50 group hover:-translate-y-2">
            
            <div class="w-14 h-14 bg-brand-dark rounded-xl mb-6 flex items-center justify-center text-white group-hover:bg-brand-black transition-colors shadow-inner">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={tecnica.icono} />
              </svg>
            </div>
            
            <h3 class="text-2xl font-bold mb-3 tracking-tight group-hover:text-brand-gray transition-colors">{tecnica.nombre}</h3>
            
            <p class="text-brand-dark text-base leading-relaxed mb-6 font-medium">
              {tecnica.descripcion}
            </p>
            
            <div class="mt-auto pt-6 border-t border-brand-light/70">
              <h4 class="text-xs tracking-wider text-brand-gray uppercase font-bold mb-2">Ideal para:</h4>
              <p class="text-sm text-brand-black italic">
                {tecnica.uso}
              </p>
            </div>
          </div>
        ))}

      </div>

      <!-- CTA -->
      <div class="mt-20 text-center bg-brand-beige p-12 rounded-2xl shadow-inner border border-brand-gray/20">
        <h3 class="text-3xl font-bold mb-4">¿Tienes una técnica específica en mente?</h3>
        <p class="text-brand-dark mb-8 max-w-2xl mx-auto text-lg">
          Nuestro taller en Bogotá está equipado para combinar técnicas (ej. Flock + Alto Relieve) y crear acabados completamente únicos para tu próxima Drop.
        </p>
        <a href="/contacto" class="px-10 py-4 bg-brand-black text-white rounded-md font-bold text-lg hover:bg-brand-gray transition-all shadow-2xl inline-block hover:scale-105 transform duration-300">
          Cotizar mi Proyecto Serigráfico
        </a>
      </div>

    </div>
  </section>
</Layout>
