---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="bg-brand-black pt-32 pb-16 px-4 sm:px-6 lg:px-8 text-center border-b border-brand-dark">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Nuestro Trabajo</h1>
    <p class="text-brand-gray max-w-2xl mx-auto text-lg">
      Explora algunos de nuestros proyectos recientes. Calidad que se ve y se siente.
    </p>
  </section>

  <!-- Portafolio Section (Migrado desde index) -->
  <section class="py-24 bg-brand-black text-white min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <!-- Item 1 -->
        <div class="group relative aspect-square overflow-hidden rounded-xl bg-brand-dark cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-t from-brand-black/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10 flex flex-col justify-end p-6">
            <h3 class="text-xl font-bold text-white">Dotación Industrial</h3>
            <p class="text-brand-light text-sm">Constructora XYZ</p>
          </div>
          <!-- Placeholder (Simulando imagen real) -->
          <div class="w-full h-full flex items-center justify-center text-brand-gray group-hover:scale-110 transition-transform duration-500">Img 1</div>
        </div>

        <!-- Item 2 -->
        <div class="group relative aspect-square overflow-hidden rounded-xl bg-brand-dark cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-t from-brand-black/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10 flex flex-col justify-end p-6">
            <h3 class="text-xl font-bold text-white">Lanyards y Credenciales</h3>
            <p class="text-brand-light text-sm">Congreso Tecnología 2024</p>
          </div>
          <div class="w-full h-full flex items-center justify-center text-brand-gray group-hover:scale-110 transition-transform duration-500">Img 2</div>
        </div>

        <!-- Item 3 -->
        <div class="group relative aspect-square overflow-hidden rounded-xl bg-brand-dark cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-t from-brand-black/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10 flex flex-col justify-end p-6">
            <h3 class="text-xl font-bold text-white">Carpas Promocionales</h3>
            <p class="text-brand-light text-sm">Activación de Marca en Verano</p>
          </div>
          <div class="w-full h-full flex items-center justify-center text-brand-gray group-hover:scale-110 transition-transform duration-500">Img 3</div>
        </div>
      </div>
      
      <div class="mt-16 text-center">
        <a href="/contacto" class="px-8 py-4 bg-white text-brand-black rounded-md font-bold text-lg hover:bg-brand-beige transition-all shadow-xl inline-block">
          Inicia tu propio Proyecto
        </a>
      </div>
    </div>
  </section>
</Layout>
