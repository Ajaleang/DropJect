---
---

<header class="fixed top-0 w-full z-50 bg-brand-black/90 backdrop-blur-md border-b border-brand-dark transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-2xl font-bold text-white tracking-wider">
          Drop<span class="text-brand-light">Ject</span>
        </a>
      </div>

      <!-- Desktop Menu -->
      <nav class="hidden md:flex space-x-8">
        <a href="#servicios" class="text-brand-gray hover:text-white transition-colors duration-200 font-medium">Servicios</a>
        <a href="#portafolio" class="text-brand-gray hover:text-white transition-colors duration-200 font-medium">Portafolio</a>
        <a href="#nosotros" class="text-brand-gray hover:text-white transition-colors duration-200 font-medium">Nosotros</a>
        <a href="#contacto" class="text-brand-gray hover:text-white transition-colors duration-200 font-medium">Contacto</a>
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:flex items-center">
        <a href="#contacto" class="bg-white text-brand-black px-6 py-2 rounded-md font-semibold hover:bg-brand-beige transition-colors duration-300">
          Cotizar Proyecto
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button type="button" class="text-brand-light hover:text-white focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
