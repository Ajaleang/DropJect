---
export interface SEOProps {
  title: string;
  description: string;
  keywords?: string;
  canonicalURL?: string;
  ogImage?: string;
  type?: 'website' | 'article' | 'product';
}

const {
  title,
  description,
  keywords = 'sublimación, dotaciones corporativas, uniformes, serigrafía, Bogotá, estampado textil, merchandising, material POP',
  canonicalURL,
  ogImage = '/og-image.jpg',
  type = 'website'
} = Astro.props;

const siteUrl = 'https://dropject.com';
const fullCanonicalURL = canonicalURL ? `${siteUrl}${canonicalURL}` : siteUrl;
const fullOgImage = ogImage.startsWith('/') ? `${siteUrl}${ogImage}` : ogImage;
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content="DropJect" />
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
<link rel="canonical" href={fullCanonicalURL} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={fullCanonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:site_name" content="DropJect" />
<meta property="og:locale" content="es_CO" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={fullCanonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />
<meta name="twitter:creator" content="@dropject" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Schema.org JSON-LD - Local Business -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "DropJect",
  "description": "Especialistas en sublimación industrial y dotaciones corporativas en Bogotá, Colombia",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.svg`,
  "image": fullOgImage,
  "telephone": "+573117694342",
  "email": "contacto@dropject.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bogotá",
    "addressRegion": "Cundinamarca",
    "addressCountry": "CO"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "4.7110",
    "longitude": "-74.0721"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "18:00"
  },
  "sameAs": [
    "https://instagram.com/dropject",
    "https://wa.me/573117694342"
  ],
  "priceRange": "$$"
})} />

<!-- Schema.org JSON-LD - Organization -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "DropJect",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.svg`,
  "sameAs": [
    "https://instagram.com/dropject",
    "https://wa.me/573117694342"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+573117694342",
    "contactType": "customer service",
    "areaServed": "CO",
    "availableLanguage": "Spanish"
  }
})} />
